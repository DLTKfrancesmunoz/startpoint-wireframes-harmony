---
/**
 * Alert Component
 *
 * Notification message with different severity levels.
 *
 * @usagePattern default-icons-per-variant Each variant has a default icon that renders automatically if no custom icon prop is provided: info→information-circle, success→check-circle, warning→exclamation-triangle, error→exclamation-circle. Override by passing a custom Heroicon name to the icon prop. The icon is always displayed regardless of variant or style.
 * @usagePattern enhanced-style-features The enhanced style (style='enhanced') unlocks additional features: vertical border accent (alert__border), support for action buttons (primaryButton/secondaryButton props), inline links (linkText/linkHref props), and progress bar (progressValue prop). These features are not available or styled properly with style='default'. Enhanced style also changes the layout to alert__content > alert__inner structure.
 * @usagePattern action-buttons-display Action buttons (primaryButton, secondaryButton) and links (linkText + linkHref) only render when style='enhanced'. Buttons are rendered as Button components with variant='primary'/'secondary' and size='xs'. Primary button always appears before secondary button in DOM order. Both buttons and links render in the alert__actions container, with buttons in alert__buttons and links as alert__link.
 * @usagePattern dismissible-behavior When dismissible=true, an X button appears in the top-right corner with aria-label="Dismiss". Clicking it removes the entire alert from the DOM using JavaScript (btn.closest('.alert')?.remove()). The dismissible button works with both default and enhanced styles, but its positioning differs based on the layout structure.
 */
import Icon from './Icon.astro';
import Button from './Button.astro';
import ProgressBar from './ProgressBar.astro';

export interface Props {
  variant?: 'info' | 'success' | 'warning' | 'error';
  style?: 'default' | 'enhanced';
  title?: string;
  dismissible?: boolean;
  icon?: string;
  primaryButton?: { text: string; href?: string; onClick?: string };
  secondaryButton?: { text: string; href?: string; onClick?: string };
  linkText?: string;
  linkHref?: string;
  progressValue?: number;
  class?: string;
}

const {
  variant = 'info',
  style = 'default',
  title,
  dismissible = false,
  icon,
  primaryButton,
  secondaryButton,
  linkText,
  linkHref,
  progressValue,
  class: className = '',
} = Astro.props;

// Default icons for each variant
const defaultIcons: Record<string, string> = {
  info: 'information-circle',
  success: 'check-circle',
  warning: 'exclamation-triangle',
  error: 'exclamation-circle',
};

const alertIcon = icon || defaultIcons[variant];

const hasActions = primaryButton || secondaryButton || (linkText && linkHref);

const classes = [
  'alert',
  `alert--${variant}`,
  style === 'enhanced' && 'alert--enhanced',
  className,
].filter(Boolean).join(' ');
---

<div class={classes} role="alert">
  {style === 'enhanced' && (
    <div class="alert__border"></div>
  )}
  {style === 'enhanced' ? (
    <div class="alert__content">
      <div class="alert__inner">
        <Icon name={alertIcon} class="alert__icon" />
        <div class="alert__text">
          {title && <div class="alert__title">{title}</div>}
          <div class="alert__message">
            <slot>Alert message. Override by passing default slot content.</slot>
          </div>
        </div>
        {dismissible && (
          <button type="button" class="alert__close" aria-label="Dismiss">
            <Icon name="x-mark" />
          </button>
        )}
      </div>
      {hasActions && (
        <div class="alert__actions">
          {(primaryButton || secondaryButton) && (
            <div class="alert__buttons">
              {primaryButton && (
                <Button
                  buttonType="theme"
                  variant="primary"
                  size="xs"
                  href={primaryButton.href}
                  onClick={primaryButton.onClick}
                >
                  {primaryButton.text}
                </Button>
              )}
              {secondaryButton && (
                <Button
                  buttonType="theme"
                  variant="secondary"
                  size="xs"
                  href={secondaryButton.href}
                  onClick={secondaryButton.onClick}
                >
                  {secondaryButton.text}
                </Button>
              )}
            </div>
          )}
          {linkText && linkHref && (
            <a href={linkHref} class="alert__link">
              {linkText}
            </a>
          )}
        </div>
      )}
      {progressValue !== undefined && (
        <div class="alert__progress">
          <ProgressBar value={progressValue} size="sm" variant={variant} />
        </div>
      )}
    </div>
  ) : (
    <>
      <Icon name={alertIcon} class="alert__icon" />
      <div class="alert__content">
        {title && <div class="alert__title">{title}</div>}
<div class="alert__message">
        <slot>Alert message. Override by passing default slot content.</slot>
        </div>
      </div>
      {dismissible && (
        <button type="button" class="alert__close" aria-label="Dismiss">
          <Icon name="x-mark" />
        </button>
      )}
    </>
  )}
</div>

<script>
  document.querySelectorAll('.alert__close').forEach((btn) => {
    btn.addEventListener('click', () => {
      btn.closest('.alert')?.remove();
    });
  });
</script>
