---
/**
 * Dropdown Component
 *
 * Dropdown select menu with custom styling.
 * Optional slots: "trigger" (replaces default trigger), "option-0" … "option-9" (custom content per option, first 10).
 *
 * @usagePattern trigger-slot-override The trigger slot (lines 75-76, 114-115) completely replaces the default trigger button, including the selected value display and chevron icon. When using a custom trigger, you are responsible for displaying the current selection state and any visual indicators. The default trigger (lines 78-82, 117-121) shows selectedOption.label or placeholder with a chevron-down icon.
 * @usagePattern option-slots-limitation Custom option content is supported via named slots option-0 through option-9 for the first 10 options only. These slots replace the option.label text but the option.value is still used for selection. Beyond 10 options, only standard label rendering is available due to Astro's static slot name requirement.
 * @usagePattern label-variant-layout When label prop is provided, labelVariant controls layout: 'inline' places label and dropdown side-by-side (default for CP theme), 'stacked' places label above dropdown (default for other themes). The wrapper gets class dropdown-wrapper--inline or dropdown-wrapper--stacked. Without explicit labelVariant, CSS handles theme-specific defaults (lines 50-56).
 */
import Icon from './Icon.astro';
import Label from './Label.astro';

export interface Option {
  value: string;
  label: string;
  disabled?: boolean;
}

export interface Props {
  options: Option[];
  value?: string;
  placeholder?: string;
  name?: string;
  id?: string;
  disabled?: boolean;
  class?: string;
  label?: string;
  labelVariant?: 'inline' | 'stacked';
  labelFor?: string;
  [key: string]: any;
}

const {
  options,
  value,
  placeholder = 'Select an option',
  name,
  id,
  disabled = false,
  class: className = '',
  label,
  labelVariant,
  labelFor,
  ...rest
} = Astro.props;

const dropdownId = id || `dropdown-${Math.random().toString(36).substr(2, 9)}`;
const selectedOption = options.find(opt => opt.value === value);

const hasTriggerSlot = Astro.slots.has('trigger');

// Determine label variant
// If explicitly provided, use that; otherwise CSS will handle default (inline for CP theme, stacked for others)
const finalLabelVariant = labelVariant;

const wrapperClasses = [
  'dropdown-wrapper',
  label && finalLabelVariant && `dropdown-wrapper--${finalLabelVariant}`,
].filter(Boolean).join(' ');

const classes = ['dropdown', className].filter(Boolean).join(' ');
---

{label ? (
  <div class={wrapperClasses}>
    <Label for={labelFor || dropdownId} class={(finalLabelVariant === 'inline' || !finalLabelVariant) ? 'dropdown-wrapper__label' : ''}>
      {label}
    </Label>
    <div class={classes} data-dropdown id={dropdownId}>
      <button
        type="button"
        class="dropdown__trigger"
        disabled={disabled}
        aria-haspopup="listbox"
        aria-expanded="false"
      >
        {hasTriggerSlot ? (
          <slot name="trigger" />
        ) : (
          <>
            <span class="dropdown__value">
              {selectedOption ? selectedOption.label : placeholder}
            </span>
            <Icon name="chevron-down" class="dropdown__chevron" />
          </>
        )}
      </button>
      
      <div class="dropdown__menu" role="listbox">
        {options.map((option, optIndex) => (
          <button
            type="button"
            class={`dropdown__item ${option.value === value ? 'is-selected' : ''} ${option.disabled ? 'dropdown__item--disabled' : ''}`}
            data-value={option.value}
            disabled={option.disabled}
            role="option"
            aria-selected={option.value === value}
          >
            {optIndex === 0 && Astro.slots.has('option-0') ? <slot name="option-0" /> : optIndex === 1 && Astro.slots.has('option-1') ? <slot name="option-1" /> : optIndex === 2 && Astro.slots.has('option-2') ? <slot name="option-2" /> : optIndex === 3 && Astro.slots.has('option-3') ? <slot name="option-3" /> : optIndex === 4 && Astro.slots.has('option-4') ? <slot name="option-4" /> : optIndex === 5 && Astro.slots.has('option-5') ? <slot name="option-5" /> : optIndex === 6 && Astro.slots.has('option-6') ? <slot name="option-6" /> : optIndex === 7 && Astro.slots.has('option-7') ? <slot name="option-7" /> : optIndex === 8 && Astro.slots.has('option-8') ? <slot name="option-8" /> : optIndex === 9 && Astro.slots.has('option-9') ? <slot name="option-9" /> : option.label}
          </button>
        ))}
      </div>
      
      <input type="hidden" name={name} value={value || ''} />
    </div>
  </div>
) : (
  <div class={classes} data-dropdown id={dropdownId}>
    <button
      type="button"
      class="dropdown__trigger"
      disabled={disabled}
      aria-haspopup="listbox"
      aria-expanded="false"
    >
      {hasTriggerSlot ? (
        <slot name="trigger" />
      ) : (
        <>
          <span class="dropdown__value">
            {selectedOption ? selectedOption.label : placeholder}
          </span>
          <Icon name="chevron-down" class="dropdown__chevron" />
        </>
      )}
    </button>
    
    <div class="dropdown__menu" role="listbox">
      {options.map((option, optIndex) => (
        <button
          type="button"
          class={`dropdown__item ${option.value === value ? 'is-selected' : ''} ${option.disabled ? 'dropdown__item--disabled' : ''}`}
          data-value={option.value}
          disabled={option.disabled}
          role="option"
          aria-selected={option.value === value}
        >
          {optIndex === 0 && Astro.slots.has('option-0') ? <slot name="option-0" /> : optIndex === 1 && Astro.slots.has('option-1') ? <slot name="option-1" /> : optIndex === 2 && Astro.slots.has('option-2') ? <slot name="option-2" /> : optIndex === 3 && Astro.slots.has('option-3') ? <slot name="option-3" /> : optIndex === 4 && Astro.slots.has('option-4') ? <slot name="option-4" /> : optIndex === 5 && Astro.slots.has('option-5') ? <slot name="option-5" /> : optIndex === 6 && Astro.slots.has('option-6') ? <slot name="option-6" /> : optIndex === 7 && Astro.slots.has('option-7') ? <slot name="option-7" /> : optIndex === 8 && Astro.slots.has('option-8') ? <slot name="option-8" /> : optIndex === 9 && Astro.slots.has('option-9') ? <slot name="option-9" /> : option.label}
        </button>
      ))}
    </div>
    
    <input type="hidden" name={name} value={value || ''} />
  </div>
)}

<script>
  function initDropdowns() {
    document.querySelectorAll('[data-dropdown]').forEach((dropdown) => {
      if (dropdown.hasAttribute('data-init')) return;
      dropdown.setAttribute('data-init', 'true');
      
      const trigger = dropdown.querySelector('.dropdown__trigger');
      const menu = dropdown.querySelector('.dropdown__menu');
      const items = dropdown.querySelectorAll('.dropdown__item');
      const hiddenInput = dropdown.querySelector('input[type="hidden"]');
      const valueDisplay = dropdown.querySelector('.dropdown__value');
      
      trigger?.addEventListener('click', () => {
        dropdown.classList.toggle('is-open');
        trigger.setAttribute('aria-expanded', dropdown.classList.contains('is-open').toString());
      });
      
      items.forEach((item) => {
        item.addEventListener('click', () => {
          const value = (item as HTMLElement).dataset.value;
          const label = item.textContent?.trim();
          
          // Update hidden input
          if (hiddenInput) (hiddenInput as HTMLInputElement).value = value || '';
          
          // Update display
          if (valueDisplay) valueDisplay.textContent = label || '';
          
          // Update selected state
          items.forEach(i => i.classList.remove('is-selected'));
          item.classList.add('is-selected');
          
          // Close dropdown
          dropdown.classList.remove('is-open');
          trigger?.setAttribute('aria-expanded', 'false');
        });
      });
      
      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!dropdown.contains(e.target as Node)) {
          dropdown.classList.remove('is-open');
          trigger?.setAttribute('aria-expanded', 'false');
        }
      });
    });
  }
  
  initDropdowns();
  document.addEventListener('astro:page-load', initDropdowns);
</script>
