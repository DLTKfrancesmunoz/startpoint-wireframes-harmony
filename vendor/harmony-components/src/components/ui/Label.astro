---
/**
 * Label Component
 *
 * Form label for inputs and other form elements.
 * Default slot: consumer-provided content (label text). No fallback; consumer must pass content for a meaningful default state.
 */

export interface Props {
  for?: string;
  required?: boolean;
  helper?: string;
  class?: string;
}

const {
  for: htmlFor,
  required = false,
  helper,
  class: className = '',
} = Astro.props;

const classes = [
  'label',
  required && 'label--required',
  className,
].filter(Boolean).join(' ');
---

<label for={htmlFor} class={classes}>
  <slot />
  {helper && <span class="label__helper"> ({helper})</span>}
</label>
