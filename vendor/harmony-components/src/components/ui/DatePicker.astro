---
/**
 * DatePicker Component
 * 
 * Simple, working date picker with calendar grid, month navigation, and date selection.
 */
import Icon from './Icon.astro';

export interface Props {
  value?: string; // ISO date string (YYYY-MM-DD)
  min?: string; // ISO date string
  max?: string; // ISO date string
  disabled?: boolean;
  locale?: string;
  id?: string;
  class?: string;
}

const {
  value,
  min,
  max,
  disabled = false,
  locale = 'en-US',
  id,
  class: className = '',
} = Astro.props;

const pickerId = id || `date-picker-${Math.random().toString(36).substr(2, 9)}`;

// Parse current date or use today
const currentDate = value ? new Date(value + 'T00:00:00') : new Date();

// Get current month/year for display
const currentMonth = currentDate.getMonth();
const currentYear = currentDate.getFullYear();

// Month names for display
const monthNames: string[] = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December'
];

// Day names for weekday headers
const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

const classes = ['date-picker', className].filter(Boolean).join(' ');
---

<div 
  class={classes} 
  id={pickerId} 
  data-date-picker
  data-month={currentMonth}
  data-year={currentYear}
  data-selected-date={value || ''}
  data-min-date={min || ''}
  data-max-date={max || ''}
  data-locale={locale}
  data-disabled={disabled.toString()}
>
  <div class="date-picker__header">
    <button 
      type="button" 
      class="date-picker__nav-btn"
      data-prev-month
      aria-label="Previous month"
      disabled={disabled}
    >
      <Icon name="chevron-left" size="sm" />
    </button>
    
    <div class="date-picker__month-year">
      <span class="date-picker__month">{monthNames[currentMonth]}</span>
      <span class="date-picker__year">{currentYear}</span>
    </div>
    
    <button 
      type="button" 
      class="date-picker__nav-btn"
      data-next-month
      aria-label="Next month"
      disabled={disabled}
    >
      <Icon name="chevron-right" size="sm" />
    </button>
  </div>
  
  <div class="date-picker__weekdays">
    {dayNames.map((day, index) => (
      <div class="date-picker__weekday" key={index} aria-label={day}>
        {day}
      </div>
    ))}
  </div>
  
  <div 
    class="date-picker__grid" 
    role="grid"
    aria-label={`Calendar for ${monthNames[currentMonth]} ${currentYear}`}
    data-calendar-grid
  >
    <!-- Calendar days will be generated client-side -->
  </div>
</div>

<script>
  function formatDate(date: Date): string {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  }
  
  function parseDate(dateStr: string): Date | null {
    if (!dateStr) return null;
    const date = new Date(dateStr + 'T00:00:00');
    return isNaN(date.getTime()) ? null : date;
  }
  
  function isSameDay(date1: Date, date2: Date): boolean {
    date1.setHours(0, 0, 0, 0);
    date2.setHours(0, 0, 0, 0);
    return date1.getTime() === date2.getTime();
  }
  
  function getCalendarDays(month: number, year: number): Array<{ date: Date; isCurrentMonth: boolean }> {
    const firstDay = new Date(year, month, 1);
    const startDate = new Date(firstDay);
    startDate.setDate(startDate.getDate() - startDate.getDay());
    
    const days: Array<{ date: Date; isCurrentMonth: boolean }> = [];
    const current = new Date(startDate);
    
    for (let i = 0; i < 42; i++) {
      days.push({
        date: new Date(current),
        isCurrentMonth: current.getMonth() === month
      });
      current.setDate(current.getDate() + 1);
    }
    
    return days;
  }
  
  function renderCalendar(picker: HTMLElement) {
    const grid = picker.querySelector('[data-calendar-grid]');
    if (!grid) return;
    
    const monthNames = [
      'January', 'February', 'March', 'April', 'May', 'June',
      'July', 'August', 'September', 'October', 'November', 'December'
    ];
    
    const month = parseInt(picker.dataset.month || '0');
    const year = parseInt(picker.dataset.year || new Date().getFullYear().toString());
    const selectedDate = picker.dataset.selectedDate || null;
    const minDate = picker.dataset.minDate || null;
    const maxDate = picker.dataset.maxDate || null;
    const locale = picker.dataset.locale || 'en-US';
    const isDisabled = picker.dataset.disabled === 'true';
    
    // Update month/year display
    const monthYearEl = picker.querySelector('.date-picker__month-year');
    if (monthYearEl) {
      const monthEl = monthYearEl.querySelector('.date-picker__month');
      const yearEl = monthYearEl.querySelector('.date-picker__year');
      if (monthEl) monthEl.textContent = monthNames[month];
      if (yearEl) yearEl.textContent = year.toString();
    }
    
    const calendarDays = getCalendarDays(month, year);
    const min = minDate ? parseDate(minDate) : null;
    const max = maxDate ? parseDate(maxDate) : null;
    const selected = selectedDate ? parseDate(selectedDate) : null;
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    
    grid.innerHTML = '';
    
    calendarDays.forEach((day) => {
      const dayDate = new Date(day.date);
      dayDate.setHours(0, 0, 0, 0);
      
      const dateStr = formatDate(dayDate);
      const isDisabledDate = (min && dayDate < min) || (max && dayDate > max);
      const isToday = isSameDay(dayDate, today);
      const isSelected = selected && isSameDay(dayDate, selected);
      
      const dayClasses = [
        'date-picker__day',
        !day.isCurrentMonth && 'date-picker__day--other-month',
        isToday && 'date-picker__day--today',
        isSelected && 'date-picker__day--selected',
        isDisabledDate && 'date-picker__day--disabled',
      ].filter(Boolean).join(' ');
      
      const button = document.createElement('button');
      button.type = 'button';
      button.className = dayClasses;
      button.setAttribute('data-date', dateStr);
      button.disabled = isDisabled || isDisabledDate;
      button.setAttribute('role', 'gridcell');
      button.setAttribute('tabindex', isSelected ? '0' : '-1');
      button.textContent = dayDate.getDate().toString();
      
      button.addEventListener('click', (e) => {
        e.stopPropagation();
        if (!isDisabled && !isDisabledDate) {
          selectDate(picker, dateStr);
        }
      });
      
      grid.appendChild(button);
    });
  }
  
  function selectDate(picker: HTMLElement, date: string) {
    picker.querySelectorAll('.date-picker__day--selected').forEach(day => {
      day.classList.remove('date-picker__day--selected');
      (day as HTMLElement).setAttribute('tabindex', '-1');
    });
    
    const selectedDay = picker.querySelector(`[data-date="${date}"]`) as HTMLElement;
    if (selectedDay) {
      selectedDay.classList.add('date-picker__day--selected');
      selectedDay.setAttribute('tabindex', '0');
    }
    
    picker.setAttribute('data-selected-date', date);
    picker.dispatchEvent(new CustomEvent('date-select', { 
      detail: { date },
      bubbles: true 
    }));
  }
  
  function initDatePicker(picker: HTMLElement) {
    let currentMonth = parseInt(picker.dataset.month || '0');
    let currentYear = parseInt(picker.dataset.year || new Date().getFullYear().toString());
    
    renderCalendar(picker);
    
    const prevBtn = picker.querySelector('[data-prev-month]');
    const nextBtn = picker.querySelector('[data-next-month]');
    
    prevBtn?.addEventListener('click', () => {
      currentMonth--;
      if (currentMonth < 0) {
        currentMonth = 11;
        currentYear--;
      }
      picker.setAttribute('data-month', currentMonth.toString());
      picker.setAttribute('data-year', currentYear.toString());
      renderCalendar(picker);
    });
    
    nextBtn?.addEventListener('click', () => {
      currentMonth++;
      if (currentMonth > 11) {
        currentMonth = 0;
        currentYear++;
      }
      picker.setAttribute('data-month', currentMonth.toString());
      picker.setAttribute('data-year', currentYear.toString());
      renderCalendar(picker);
    });
  }
  
  function initDatePickers() {
    document.querySelectorAll('[data-date-picker]:not([data-initialized])').forEach((picker) => {
      picker.setAttribute('data-initialized', 'true');
      initDatePicker(picker as HTMLElement);
    });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDatePickers);
  } else {
    initDatePickers();
  }
  
  document.addEventListener('astro:page-load', initDatePickers);
</script>
