---
/**
 * CheckboxGroup Component
 *
 * Wrapper component for grouping checkboxes with optional error/warning states.
 * Accepts children via slot (composition pattern).
 *
 * @usagePattern group-vs-individual-validation CheckboxGroup provides group-level error and warning states via error, warning, errorMessage, and warningMessage props. These are distinct from individual Checkbox component error/warning props. Group-level messages appear below all checkboxes in checkbox-group-wrapper__message, while individual checkbox messages appear directly below each checkbox. Use group validation for "at least one required" errors, individual validation for per-checkbox constraints.
 * @usagePattern fieldset-legend-semantics CheckboxGroup renders as a <fieldset> element with optional <legend> for the legend prop. This provides semantic grouping for assistive technologies. The fieldset receives aria-invalid='true' when error=true and aria-describedby linking to the group error/warning message. This is the correct HTML structure for checkbox groups and ensures screen readers announce the group context.
 * @usagePattern composition-pattern CheckboxGroup uses slot composition - it doesn't generate individual Checkbox components. You must manually nest Checkbox components inside CheckboxGroup's default slot. This allows full control over each checkbox's props (name, value, label, checked) while the group wrapper provides shared styling, layout (orientation prop), and group-level validation states.
 * @usagePattern error-takes-precedence When both error and warning are true, only the error state displays. The errorMessage is shown with checkbox-group-wrapper__message--error class and exclamation-circle icon. The warning is completely suppressed (conditional !error && warning) to avoid conflicting visual states. Set only one of error or warning to true at a time.
 */
import Icon from './Icon.astro';

export interface Props {
  legend?: string;
  error?: boolean;
  warning?: boolean;
  errorMessage?: string;
  warningMessage?: string;
  orientation?: 'vertical' | 'horizontal';
  class?: string;
}

const {
  legend,
  error = false,
  warning = false,
  errorMessage,
  warningMessage,
  orientation = 'vertical',
  class: className = '',
} = Astro.props;

const groupId = `checkbox-group-${Math.random().toString(36).substr(2, 9)}`;
const messageId = error && errorMessage ? `${groupId}-error` : warning && warningMessage ? `${groupId}-warning` : undefined;

const wrapperClasses = [
  'checkbox-group-wrapper',
  error && 'checkbox-group-wrapper--error',
  warning && 'checkbox-group-wrapper--warning',
  orientation === 'horizontal' && 'checkbox-group-wrapper--horizontal',
  className,
].filter(Boolean).join(' ');

const legendClasses = [
  'checkbox-group-wrapper__legend',
  error && 'checkbox-group-wrapper__legend--error',
  warning && 'checkbox-group-wrapper__legend--warning',
].filter(Boolean).join(' ');
---

<fieldset class={wrapperClasses} aria-invalid={error ? 'true' : undefined} aria-describedby={messageId}>
  {legend && (
    <legend class={legendClasses}>{legend}</legend>
  )}
  <div class="checkbox-group-wrapper__content">
    <slot />
  </div>
  {error && errorMessage && (
    <p id={messageId} class="checkbox-group-wrapper__message checkbox-group-wrapper__message--error">
      <Icon name="exclamation-circle" size="sm" class="checkbox-group-wrapper__message-icon" />
      {errorMessage}
    </p>
  )}
  {!error && warning && warningMessage && (
    <p id={messageId} class="checkbox-group-wrapper__message checkbox-group-wrapper__message--warning">
      <Icon name="exclamation-triangle" size="sm" class="checkbox-group-wrapper__message-icon" />
      {warningMessage}
    </p>
  )}
</fieldset>
