---
/**
 * Input Component
 *
 * Text input for collecting user data with various states.
 *
 * @usagePattern label-layout-variants When a label prop is provided, the input renders in a form wrapper with Label component. The labelVariant prop ('inline' or 'stacked') controls layout: inline places label and input side-by-side (default for CP theme via CSS), stacked places label above input (default for other themes). If labelVariant is not explicitly set, CSS theme variables determine the default layout. When no label prop is provided, the input renders without a wrapper.
 * @usagePattern auto-generated-ids If no id prop is provided, the component automatically generates a unique random ID using Math.random().toString(36).substr(2, 9). This auto-generated ID is used for label[for] attribute, aria-describedby linking to error messages, and the input element itself. Always provide an explicit id for server-side rendered forms to ensure consistent IDs across renders.
 * @usagePattern icon-position-leading The icon prop only supports leading (left-side) icon placement. When icon is provided (Heroicon name string), the input renders with input--with-icon class and Icon component with size='sm' in input-wrapper__icon. There is no iconPosition prop; icons are always positioned on the left side of the input field.
 * @usagePattern error-state-accessibility When error=true and errorMessage is provided, the component creates an error paragraph with id={inputId}-error, applies aria-invalid='true' to the input, and links them via aria-describedby={inputId}-error. This ensures screen readers announce errors when the input receives focus. The errorMessage displays in input-wrapper__error class below the input field.
 */
import Icon from './Icon.astro';
import Label from './Label.astro';

export interface Props {
  type?: 'text' | 'email' | 'password' | 'number' | 'url' | 'search' | 'tel';
  placeholder?: string;
  value?: string;
  name?: string;
  id?: string;
  disabled?: boolean;
  error?: boolean;
  errorMessage?: string;
  icon?: string; // Heroicon name (e.g., "magnifying-glass", "envelope")
  required?: boolean;
  label?: string;
  labelVariant?: 'inline' | 'stacked';
  labelFor?: string;
  class?: string;
  [key: string]: any;
}

const {
  type = 'text',
  placeholder,
  value,
  name,
  id,
  disabled = false,
  error = false,
  errorMessage,
  icon,
  required = false,
  label,
  labelVariant,
  labelFor,
  class: className = '',
  ...rest
} = Astro.props;

// Build class list
const inputClasses = [
  'input',
  icon && 'input--with-icon',
  error && 'input--error',
  className,
].filter(Boolean).join(' ');

const inputId = id || `input-${Math.random().toString(36).substr(2, 9)}`;

// Determine label variant
// If explicitly provided, use that; otherwise CSS will handle default (inline for CP theme, stacked for others)
const finalLabelVariant = labelVariant;

const wrapperClasses = [
  'input-form-wrapper',
  label && finalLabelVariant && `input-form-wrapper--${finalLabelVariant}`,
].filter(Boolean).join(' ');
---

{label ? (
  <div class={wrapperClasses}>
    <Label for={labelFor || inputId} class={(finalLabelVariant === 'inline' || !finalLabelVariant) ? 'input-form-wrapper__label' : ''}>
      {label}
    </Label>
    <div class="input-wrapper">
      {icon && (
        <Icon name={icon} size="sm" class="input-wrapper__icon" />
      )}
      
      <input
        type={type}
        placeholder={placeholder}
        value={value}
        name={name}
        id={inputId}
        disabled={disabled}
        required={required}
        class={inputClasses}
        aria-invalid={error ? 'true' : undefined}
        aria-describedby={error && errorMessage ? `${inputId}-error` : undefined}
        {...rest}
      />
      
      {error && errorMessage && (
        <p 
          id={`${inputId}-error`}
          class="input-wrapper__error"
        >
          {errorMessage}
        </p>
      )}
    </div>
  </div>
) : (
  <div class="input-wrapper">
    {icon && (
      <Icon name={icon} size="sm" class="input-wrapper__icon" />
    )}
    
    <input
      type={type}
      placeholder={placeholder}
      value={value}
      name={name}
      id={inputId}
      disabled={disabled}
      required={required}
      class={inputClasses}
      aria-invalid={error ? 'true' : undefined}
      aria-describedby={error && errorMessage ? `${inputId}-error` : undefined}
      {...rest}
    />
    
    {error && errorMessage && (
      <p 
        id={`${inputId}-error`}
        class="input-wrapper__error"
      >
        {errorMessage}
      </p>
    )}
  </div>
)}
