---
/**
 * NumberInput Component
 *
 * Number input with increment/decrement buttons.
 */
import Icon from './Icon.astro';
import Label from './Label.astro';

export interface Props {
  value?: number;
  min?: number;
  max?: number;
  step?: number;
  name?: string;
  id?: string;
  disabled?: boolean;
  label?: string;
  labelVariant?: 'inline' | 'stacked';
  labelFor?: string;
  class?: string;
  [key: string]: any;
}

const {
  value = 0,
  min,
  max,
  step = 1,
  name,
  id,
  disabled = false,
  label,
  labelVariant,
  labelFor,
  class: className = '',
  ...rest
} = Astro.props;

const numberInputId = id || `number-input-${Math.random().toString(36).substr(2, 9)}`;

// Determine label variant
// If explicitly provided, use that; otherwise CSS will handle default (inline for CP theme, stacked for others)
const finalLabelVariant = labelVariant;

const wrapperClasses = [
  'number-input-form-wrapper',
  label && finalLabelVariant && `number-input-form-wrapper--${finalLabelVariant}`,
].filter(Boolean).join(' ');

const classes = ['number-input', className].filter(Boolean).join(' ');
---

{label ? (
  <div class={wrapperClasses}>
    <Label for={labelFor || numberInputId} class={(finalLabelVariant === 'inline' || !finalLabelVariant) ? 'number-input-form-wrapper__label' : ''}>
      {label}
    </Label>
    <div class={classes} data-number-input>
      <button
        type="button"
        class="number-input__btn"
        data-number-input-decrement
        disabled={disabled || (min !== undefined && value <= min)}
        aria-label="Decrease"
      >
        <Icon name="minus" />
      </button>
      <input
        type="number"
        value={value}
        min={min}
        max={max}
        step={step}
        name={name}
        id={numberInputId}
        disabled={disabled}
        class="number-input__input"
        {...rest}
      />
      <button
        type="button"
        class="number-input__btn"
        data-number-input-increment
        disabled={disabled || (max !== undefined && value >= max)}
        aria-label="Increase"
      >
        <Icon name="plus" />
      </button>
    </div>
  </div>
) : (
  <div class={classes} data-number-input>
    <button
      type="button"
      class="number-input__btn"
      data-number-input-decrement
      disabled={disabled || (min !== undefined && value <= min)}
      aria-label="Decrease"
    >
      <Icon name="minus" />
    </button>
    <input
      type="number"
      value={value}
      min={min}
      max={max}
      step={step}
      name={name}
      id={numberInputId}
      disabled={disabled}
      class="number-input__input"
      {...rest}
    />
    <button
      type="button"
      class="number-input__btn"
      data-number-input-increment
      disabled={disabled || (max !== undefined && value >= max)}
      aria-label="Increase"
    >
      <Icon name="plus" />
    </button>
  </div>
)}

<script>
  function initNumberInputs() {
    document.querySelectorAll('[data-number-input]').forEach((numberInput) => {
      if (numberInput.hasAttribute('data-init')) return;
      numberInput.setAttribute('data-init', 'true');
      
      const input = numberInput.querySelector('.number-input__input') as HTMLInputElement;
      const decrementBtn = numberInput.querySelector('[data-number-input-decrement]') as HTMLButtonElement;
      const incrementBtn = numberInput.querySelector('[data-number-input-increment]') as HTMLButtonElement;
      
      if (!input || !decrementBtn || !incrementBtn) return;
      
      const step = parseFloat(input.step) || 1;
      const min = input.min ? parseFloat(input.min) : undefined;
      const max = input.max ? parseFloat(input.max) : undefined;
      
      function updateButtons() {
        const val = parseFloat(input.value) || 0;
        decrementBtn.disabled = input.disabled || (min !== undefined && val <= min);
        incrementBtn.disabled = input.disabled || (max !== undefined && val >= max);
      }
      
      decrementBtn.addEventListener('click', () => {
        const val = parseFloat(input.value) || 0;
        const newVal = val - step;
        if (min === undefined || newVal >= min) {
          input.value = newVal.toString();
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
        updateButtons();
      });
      
      incrementBtn.addEventListener('click', () => {
        const val = parseFloat(input.value) || 0;
        const newVal = val + step;
        if (max === undefined || newVal <= max) {
          input.value = newVal.toString();
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
        updateButtons();
      });
      
      input.addEventListener('input', updateButtons);
    });
  }
  
  initNumberInputs();
  document.addEventListener('astro:page-load', initNumberInputs);
</script>
