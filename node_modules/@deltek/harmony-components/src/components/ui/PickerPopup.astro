---
/**
 * PickerPopup Component
 *
 * Reusable popup container for date/time pickers.
 * Positions relative to trigger element with clean event delegation.
 *
 * REBUILT FROM SCRATCH - No global functions, no race conditions.
 */
import Icon from './Icon.astro';

export interface Props {
  id: string;
  triggerId?: string;
  class?: string;
  title?: string;
}

const {
  id,
  triggerId,
  class: className = '',
  title,
} = Astro.props;

const classes = ['picker-popup', className].filter(Boolean).join(' ');
---

<div
  class={classes}
  id={id}
  role="dialog"
  aria-modal="true"
  aria-labelledby={title ? `${id}-title` : undefined}
  data-picker-popup
  data-trigger-id={triggerId || ''}
>
  {title && (
    <div class="picker-popup__header">
      <h3 class="picker-popup__title" id={`${id}-title`}>{title}</h3>
      <button
        type="button"
        class="picker-popup__close"
        data-picker-close
        aria-label="Close picker"
      >
        <Icon name="x-mark" size="sm" />
      </button>
    </div>
  )}
  <div class="picker-popup__body">
    <slot>
      <p class="picker-popup__body-default">Picker content. Override by passing default slot content.</p>
    </slot>
  </div>
</div>

<script>
  /**
   * Clean event delegation system for all pickers
   * No global functions, no timing hacks, no race conditions
   *
   * State management is handled in DateInput.astro
   * This component only handles global event delegation
   */

  let initialized = false;

  /**
   * Handle Escape key to close all open pickers
   */
  function handleEscapeKey(e: KeyboardEvent): void {
    if (e.key === 'Escape') {
      document.querySelectorAll('[data-picker-popup].is-open').forEach(popup => {
        popup.classList.remove('is-open');
      });
    }
  }

  /**
   * Handle clicks outside popups to close them
   * Uses composedPath for reliable "outside" detection
   */
  function handleClickOutside(e: MouseEvent): void {
    const target = e.target as HTMLElement;
    const path = e.composedPath();

    document.querySelectorAll('[data-picker-popup].is-open').forEach(popup => {
      const triggerId = popup.getAttribute('data-trigger-id');
      const wrapper = triggerId
        ? document.getElementById(triggerId)?.closest('.date-input-wrapper')
        : null;

      // Check if click is outside both popup AND wrapper
      const clickedOutside = !path.includes(popup) && (!wrapper || !path.includes(wrapper));

      if (clickedOutside) {
        popup.classList.remove('is-open');
      }
    });
  }


  /**
   * Handle close button clicks
   */
  function handleCloseButton(): void {
    document.querySelectorAll('[data-picker-popup]:not([data-close-init])').forEach(popup => {
      popup.setAttribute('data-close-init', 'true');

      const closeBtn = popup.querySelector('[data-picker-close]');
      closeBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        popup.classList.remove('is-open');
      });
    });
  }

  /**
   * Initialize picker system
   * Attaches global event delegation handlers once
   */
  function initPickerSystem(): void {
    if (initialized) return;
    initialized = true;

    // Global event delegation
    document.addEventListener('keydown', handleEscapeKey);
    document.addEventListener('click', handleClickOutside);

    // Close button handlers
    handleCloseButton();
  }

  initPickerSystem();
  document.addEventListener('astro:page-load', () => {
    // Re-init close buttons on page load (Astro navigation)
    handleCloseButton();
  });
</script>
