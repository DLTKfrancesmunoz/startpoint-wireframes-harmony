---
/**
 * Shell Page Header Component
 *
 * Header component that appears above page content cards in the shell layout.
 * Displays title and subtitle on the left, with up to 4 optional action buttons on the right.
 * By default shows one dark blue primary button (far right) and one outline secondary button (left of primary) when no button props are passed. Pass showDefaultButtons={false} to hide buttons, or pass primaryButton/outlineButton1 to override.
 * @usagePattern actions-order In the actions slot, DOM order equals visual order; ShellPageHeader does not reorder. Place outline/secondary buttons first (left), primary button last (right) to match Harmony design. When using props only, the component renders outline buttons then primary by default.
 */
import Button from './Button.astro';

export interface ButtonConfig {
  text: string;
  icon?: string;
  href?: string;
}

const DEFAULT_PRIMARY: ButtonConfig = { text: 'Primary' };
const DEFAULT_OUTLINE: ButtonConfig = { text: 'Secondary' };

export interface Props {
  title: string;
  subtitle?: string;
  /** When true (default), show one primary and one outline button when no button props are passed. Set to false to show no buttons when none are provided. */
  showDefaultButtons?: boolean;
  primaryButton?: ButtonConfig;
  outlineButton1?: ButtonConfig;
  outlineButton2?: ButtonConfig;
  outlineButton3?: ButtonConfig;
  class?: string;
}

const {
  title,
  subtitle,
  showDefaultButtons = true,
  primaryButton,
  outlineButton1,
  outlineButton2,
  outlineButton3,
  class: className = '',
} = Astro.props;

const hasActionsSlot = Astro.slots.has('actions');
const useDefaultButtons =
  showDefaultButtons &&
  primaryButton === undefined &&
  outlineButton1 === undefined &&
  outlineButton2 === undefined &&
  outlineButton3 === undefined &&
  !hasActionsSlot;

// Effective configs: use defaults when no button props passed, else use props as-is
const effectiveOutline1 = useDefaultButtons ? DEFAULT_OUTLINE : outlineButton1;
const effectiveOutline2 = outlineButton2;
const effectiveOutline3 = outlineButton3;
const effectivePrimary = useDefaultButtons ? DEFAULT_PRIMARY : primaryButton;

const outlineButtons = [effectiveOutline1, effectiveOutline2, effectiveOutline3].filter(
  (b): b is ButtonConfig => Boolean(b)
);
const showDefaultActions = outlineButtons.length > 0 || effectivePrimary;
---

<header class={`shell-page-header ${className}`}>
  <div class="shell-page-header__left">
    <h1 class="shell-page-header__title">{title}</h1>
    {subtitle && <p class="shell-page-header__subtitle">{subtitle}</p>}
  </div>
  
  {hasActionsSlot ? (
    <div class="shell-page-header__actions">
      <slot name="actions" />
    </div>
  ) : showDefaultActions ? (
    <div class="shell-page-header__actions">
      {outlineButtons.map((button) => (
        <Button
          variant="secondary"
          buttonType="pageHeader"
          size="md"
          icon={button.icon}
          href={button.href}
        >
          {button.text}
        </Button>
      ))}
      {effectivePrimary && (
        <Button
          variant="primary"
          buttonType="pageHeader"
          size="md"
          icon={effectivePrimary.icon}
          href={effectivePrimary.href}
        >
          {effectivePrimary.text}
        </Button>
      )}
    </div>
  ) : null}
</header>

<style>
  .shell-page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) 0;
    margin-bottom: var(--space-3);
    gap: var(--space-4);
  }

  .shell-page-header__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 1;
    min-width: 0;
  }

  .shell-page-header__title {
    font-family: var(--font-display);
    font-size: var(--heading-l);
    font-weight: var(--font-semibold);
    line-height: var(--leading-snug);
    color: var(--text-primary);
    margin: 0;
  }

  .shell-page-header__subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--font-normal);
    line-height: var(--leading-normal);
    color: var(--text-secondary);
    margin: 0;
  }

  .shell-page-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  /* Override outline button backgrounds to be transparent */
  .shell-page-header__actions .btn--page-header.btn--secondary {
    background-color: transparent;
  }

  .shell-page-header__actions .btn--page-header.btn--secondary:hover {
    background-color: var(--page-header-btn-secondary-hover-bg);
  }

  .shell-page-header__actions .btn--page-header.btn--secondary:disabled,
  .shell-page-header__actions .btn--page-header.btn--secondary.btn--disabled {
    background-color: transparent;
  }

  /* Responsive behavior */
  @media (max-width: var(--breakpoint-md)) {
    .shell-page-header {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-4);
    }

    .shell-page-header__actions {
      flex-wrap: wrap;
      width: 100%;
    }

    .shell-page-header__actions .btn {
      flex: 1;
      min-width: 120px;
    }
  }
</style>
